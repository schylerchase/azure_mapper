{
  "name": "azure-network-mapper",
  "version": "1.2.0",
  "description": "Azure Network Topology Mapper - Desktop Application",
  "author": {
    "name": "schylerchase",
    "email": "schylerchase@users.noreply.github.com"
  },
  "homepage": "https://github.com/schylerchase/Azure-Mapper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "node build.js && electron .",
    "watch": "node build.js --watch",
    "bundle": "node build.js",
    "bundle:prod": "node build.js --production",
    "build": "npm run bundle:prod && electron-builder",
    "build:mac": "npm run bundle:prod && electron-builder --mac",
    "build:win": "npm run bundle:prod && electron-builder --win",
    "build:linux": "npm run bundle:prod && electron-builder --linux",
    "build:web": "node build.js --production && node build-web.js",
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:unit": "jest && node --test tests/unit/*.test.mjs",
    "test:jest": "jest",
    "test:node": "node --test tests/unit/*.test.mjs",
    "test:all": "jest && node --test tests/unit/*.test.mjs && npx playwright test"
  },
  "build": {
    "appId": "com.schylerchase.azure-network-mapper",
    "productName": "Azure Network Mapper",
    "files": [
      "index.html",
      "main.js",
      "main-utils.js",
      "preload.js",
      "export-azure-data.sh",
      "routing.js",
      "libs/**",
      "dist/app.bundle.js",
      "dist/app-core.js",
      "src/styles/**",
      "src/data/**",
      "logo.png",
      "icon.png"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "Azure-Network-Mapper-Setup-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "schylerchase",
      "repo": "Azure-Mapper"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "d3-ease": "^3.0.1",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.7.0",
    "esbuild": "^0.27.3",
    "jest": "^29.7.0",
    "serve": "^14.2.5"
  },
  "dependencies": {
    "electron-updater": "^6.7.3"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/routing.test.js",
      "<rootDir>/main-utils.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "\\.spec\\.js$",
      "\\.spec\\.ts$"
    ],
    "transform": {}
  },
  "overrides": {
    "minimatch@<3.1.5": "3.1.5",
    "minimatch@>=5.0.0 <5.1.8": "5.1.8",
    "minimatch@>=9.0.0 <9.0.7": "9.0.7",
    "minimatch@>=10.0.0 <10.2.3": "10.2.4",
    "tar@<=7.5.10": "7.5.11"
  }
}
